    {
      "name": "Webhooks",
      "description": "Endpoints para receber eventos de sistemas externos.",
      "item": [
        {
          "name": "Stripe Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Stripe-Signature",
                "value": "t=1714000000,v1=abc123...",
                "description": "Assinatura HMAC-SHA256 gerada pelo Stripe. Em ambiente real é gerada automaticamente pelo Stripe CLI."
              }
            ],
            "auth": {
              "type": "noauth"
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"id\": \"evt_1RAbcdefXXX\",\n  \"object\": \"event\",\n  \"type\": \"invoice.paid\",\n  \"data\": {\n    \"object\": {\n      \"id\": \"in_1RAbcdefXXX\",\n      \"object\": \"invoice\",\n      \"subscription\": \"sub_1RAbcdefXXX\",\n      \"status\": \"paid\"\n    }\n  }\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{base_url}}/v1/webhooks/stripe",
              "host": ["{{base_url}}"],
              "path": ["v1", "webhooks", "stripe"]
            },
            "description": "Endpoint para receber webhooks do Stripe. A assinatura HMAC é validada com `STRIPE_WEBHOOK_SECRET`. Use `stripe listen --forward-to localhost:8080/v1/webhooks/stripe` para testar localmente.\n\nEventos processados:\n- `invoice.paid` — ativa assinatura\n- `invoice.payment_failed` — marca como past_due\n- `customer.subscription.updated` — atualiza plano\n- `customer.subscription.deleted` — cancela assinatura\n- `checkout.session.completed` — salva stripe_customer_id"
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// Stripe validará a assinatura — este teste usa payload de exemplo sem assinatura válida",
                  "pm.test('Resposta recebida (400 esperado sem assinatura válida)', () => {",
                  "  pm.expect([200, 400]).to.include(pm.response.code);",
                  "});"
                ]
              }
            }
          ],
          "response": [
            {
              "name": "200 Evento processado",
              "status": "OK",
              "code": 200,
              "header": [],
              "body": ""
            },
            {
              "name": "400 Assinatura inválida",
              "status": "Bad Request",
              "code": 400,
              "header": [
                { "key": "Content-Type", "value": "application/json" }
              ],
              "body": "{\n  \"error\": \"invalid signature\"\n}"
            }
          ]
        }
      ]
    },
