# ─────────────────────────────────────────────────────────────────────────────
# Nota MEI Gateway — Variáveis de ambiente
# Copie para .env e preencha com os valores reais (nunca commite .env)
# ─────────────────────────────────────────────────────────────────────────────

# App
APP_ENV=development           # development | staging | production
PORT=8080
LOG_LEVEL=info                # trace | debug | info | warn | error

# Supabase (Railway Railway → Supabase)
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Redis (Railway add-on — em prod é injetado automaticamente)
REDIS_URL=redis://localhost:6379

# RabbitMQ (CloudAMQP)
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# AWS (certificados A1 via Secrets Manager)
AWS_REGION=sa-east-1
AWS_KMS_KEY_ARN=arn:aws:kms:sa-east-1:ACCOUNT_ID:key/KEY_ID
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_BASIC=price_...
STRIPE_PRICE_PRO=price_...
STRIPE_PRICE_BUSINESS=price_...

# Receita Federal NFS-e Nacional
RECEITA_API_URL=https://homologacao.nfse.gov.br/m/app/api/recepcionar-lote-rps/v1

# ── Next.js (Vercel / Local) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
